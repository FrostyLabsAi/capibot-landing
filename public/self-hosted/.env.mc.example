# Mission Control Configuration
# Copy this file to .env.mc and fill in your values

# ── Session Secret (generate a random 64-char hex string) ──
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── CapiBot Connection (must match .env values) ──
CAPIBOT_API_KEY=same-as-CAPIBOT_API_KEY-in-dotenv
CAPIBOT_GATEWAY_TOKEN=same-as-CAPIBOT_GATEWAY_TOKEN-in-dotenv

# ── Allowed Hosts (comma-separated, adjust for your domain) ──
MC_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Optional: WebSocket host for browser connections ──
# NEXT_PUBLIC_GATEWAY_HOST=localhost:3001
