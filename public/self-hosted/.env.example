# CapiBot Self-Hosted Configuration
# Copy this file to .env and fill in your values

# ── License (required) ──
CAPIBOT_LICENSE_KEY=CAPI-XXXX-XXXX-XXXX-XXXX

# ── Database ──
DB_PASSWORD=change-me-to-a-strong-random-password

# ── Security (generate random strings for each) ──
CAPIBOT_API_KEY=change-me-to-a-random-64-char-hex-string
JWT_SECRET=change-me-to-a-random-64-char-hex-string
CAPIBOT_GATEWAY_TOKEN=change-me-to-a-random-base64-string

# ── Admin Login ──
CAPIBOT_ADMIN_PASSWORD=change-me

# ── LLM Providers (set at least one) ──
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...
# ALIBABA_API_KEY=sk-sp-...
# KIMI_API_KEY=...
# GLM_API_KEY=...
# MINIMAX_API_KEY=...

# ── Provider Priority (comma-separated, first available wins) ──
# CAPIBOT_PROVIDER_PRIORITY=anthropic,gemini,alibaba,kimi,glm,minimax,ollama

# ── Ollama LLM fallback (optional — embeddings are handled automatically) ──
# Ollama runs as a bundled container for embeddings (nomic-embed-text).
# To also use it as an LLM fallback, pull a model: docker compose exec ollama ollama pull llama3.2
# OLLAMA_MODEL=llama3.2

# ── Optional: Telegram Bot ──
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Optional: Ports (defaults shown) ──
# CAPIBOT_API_PORT=3000
# CAPIBOT_WS_PORT=3001
# MC_PORT=3002

# ── WebSocket allowed origins (adjust for your domain) ──
CAPIBOT_WS_ALLOWED_ORIGINS=http://localhost:3002
